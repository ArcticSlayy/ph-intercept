PROVIDER=technitium

# Browser-facing Technitium UI link.
TECHNITIUM_DASHBOARD=http://127.0.0.1:5380

# Container-facing Technitium API URL.
# On Docker Desktop, host.docker.internal reaches the Windows host.
TECHNITIUM_API_URL=http://host.docker.internal:5380
TECHNITIUM_VERIFY_SSL=true

# Prefer an API token from a dedicated, limited Technitium user.
# Keep this file as an example; put real secrets in an untracked .env.
TECHNITIUM_API_TOKEN=
# Optional session-login fallback when no token is available.
# TECHNITIUM_API_USER=
# TECHNITIUM_API_PASSWORD=
# TECHNITIUM_API_TOTP=

# Query Logs API settings. These are sent to Technitium's /api/logs/query.
# The provider does not read a local query-log database file directly.
TECHNITIUM_API_QUERY_LOG_NAME=Query Logs (Sqlite)
TECHNITIUM_API_QUERY_LOG_CLASS_PATH=QueryLogsSqlite.App
TECHNITIUM_API_STATS_TYPE=LastDay
TECHNITIUM_API_ENTRIES_PER_PAGE=50
TECHNITIUM_API_POLL_SECONDS=1.0
TECHNITIUM_REPLAY_RECENT=20
TECHNITIUM_REPLAY_MAX_AGE_SECONDS=120

# Observe-only by default. Set true only if the token/user may modify settings.
TECHNITIUM_API_ALLOW_CONTROL=false

# Optional defender labels for Squadron mode.
# Format: client-ip-or-hostname=label,client-ip-or-hostname=label
# Example: ::1=Local Host,127.0.0.1=Local Host,192.168.1.50=Living Room TV
TECHNITIUM_CLIENT_NAMES=
# Optional custom domain labels. This affects display labels only.
# TECHNITIUM_DOMAIN_LABELS=(^|\.)ads\.example\.com$=Example Ads
# TECHNITIUM_DOMAIN_LABEL_MODE=prefix
# TECHNITIUM_INFER_DOMAIN_LABELS=true
# TECHNITIUM_IGNORE_DOMAINS=.*\.local$,.*\.home\.arpa$

# Localhost-only compose port binding is the default. Change compose.technitium.yaml
# from 127.0.0.1:4653:4653 to 4653:4653 only behind LAN/VPN/reverse-proxy auth.
PH_INTERCEPT_ALLOWED_ORIGINS=
PH_INTERCEPT_FRAME_ANCESTORS='self'
